#!/bin/bash
set -euo pipefail

PYTHON312_BIN="/var/apps/python312/target/bin/python3"

LOG_FILE="${TRIM_TEMP_LOGFILE:-/tmp/f2_web_app_install.log}"
exec >> "${LOG_FILE}" 2>&1

SERVER_DIR="${TRIM_APPDEST}/server"
REQ_FILE="${SERVER_DIR}/requirements.txt"
VENV_DIR="${TRIM_PKGVAR}/.venv"

mkdir -p "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/state" "${TRIM_PKGVAR}/downloads"

if [ ! -f "${REQ_FILE}" ]; then
    echo "requirements.txt not found: ${REQ_FILE}"
    exit 1
fi

if [ ! -x "${PYTHON312_BIN}" ]; then
    echo "Python 3.12 not found at ${PYTHON312_BIN}. Please ensure install_dep_apps=python312 is installed."
    exit 1
fi

echo "Using Python: ${PYTHON312_BIN}"
"${PYTHON312_BIN}" --version

if [ ! -d "${VENV_DIR}" ]; then
    "${PYTHON312_BIN}" -m venv "${VENV_DIR}"
fi

WHEELS_DIR="${SERVER_DIR}/wheels"

"${VENV_DIR}/bin/python3" -m pip install --no-index --find-links "${WHEELS_DIR}" --upgrade pip

# 先安装构建依赖，以防有源码包需要构建
"${VENV_DIR}/bin/pip" install --no-index --find-links "${WHEELS_DIR}" setuptools wheel 2>/dev/null || true

"${VENV_DIR}/bin/pip" install --no-index --find-links "${WHEELS_DIR}" -r "${REQ_FILE}"

exit 0
